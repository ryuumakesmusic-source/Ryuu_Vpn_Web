# ─────────────────────────────────────────────────────────────────────────────
#  RYUU VPN — Environment Variables Template
#  Copy this file to .env and fill in your values.
#  The setup.sh script generates .env automatically on first install.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Set automatically by docker-compose from DB_PASSWORD below.
DATABASE_URL=postgresql://ryuu:CHANGE_ME@db:5432/ryuuvpn

# Used by the db container in docker-compose.yml
DB_PASSWORD=CHANGE_ME

# ── App ───────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
LOG_LEVEL=info

# ── Auth ──────────────────────────────────────────────────────────────────────
# Random secret for signing JWTs. Generate with: openssl rand -base64 48
SESSION_SECRET=CHANGE_ME

# Password for the seeded admin accounts (ryuu and sayuri).
# If not set, falls back to dev defaults: ryuu123 / sayuri123 (NOT for production).
ADMIN_SECRET=CHANGE_ME

# ── Remnawave VPN Panel ───────────────────────────────────────────────────────
REMNAWAVE_URL=https://panel.ryuukakkoii.site
REMNAWAVE_API_KEY=CHANGE_ME

# ── Telegram — Notification Bot ───────────────────────────────────────────────
# This bot sends admin payment alerts (top-up submissions, approvals, rejections).
# Create via @BotFather. Must be in all admin chats.
TELEGRAM_BOT_TOKEN=CHANGE_ME

# Comma-separated Telegram chat IDs to receive admin notifications.
# Example: 123456789,987654321
TELEGRAM_ADMIN_CHAT_IDS=CHANGE_ME

# ── Telegram — Mini App Bot ───────────────────────────────────────────────────
# This bot handles /start and /help commands and sends users a button to open the shop.
# Create a separate bot via @BotFather. Webhook is registered automatically on startup.
# Leave empty if you don't want a Mini App bot.
MINI_BOT_TOKEN=

# The public URL of your app (used to build the webhook URL).
MINI_APP_URL=https://ryuukakkoii.site

# Secret token for verifying Telegram webhook calls (recommended).
# Generate with: openssl rand -base64 48
BOT_WEBHOOK_SECRET=CHANGE_ME
